# shell variables
set -x PAGER less
set -x EDITOR hx
set -x VISUAL hx
set -x HISTSIZE 5000
set -x HISTFILESIZE 1000
set -x HISTCONTROL ignoredups
set -x HISTIGNORE "&:ls:ll:la:lr:l.:pwd:exit:clear"
set -x HOMEBREW_NO_ANALYTICS 1
set -x CDPATH .:..:$HOME/Projects:$HOME:$HOME/Documents

switch (uname) 
    case Darwin 
        set -x CANGJIE_HOME "/opt/homebrew/opt/cangjie"
        if set -q DYLD_LIBRARY_PATH
          set -x DYLD_LIBRARY_PATH $CANGJIE_HOME/lib $DYLD_LIBRARY_PATH
        else
          set -x DYLD_LIBRARY_PATH $CANGJIE_HOME/lib
        end

    case Linux
        set -x CANGJIE_HOME "/opt/cangjie"
        if set -q LD_LIBRARY_PATH
          set -x LD_LIBRARY_PATH $CANGJIE_HOME/lib $LD_LIBRARY_PATH
        else
          set -x LD_LIBRARY_PATH $CANGJIE_HOME/lib
        end

end

set -x PATH $HOME/bin $HOME/.local/bin /opt/homebrew/bin $CANGJIE_HOME/bin $PATH 
